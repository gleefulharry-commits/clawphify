      "key_settings": ["channels.*.allowFrom", "channels.*.groups", "messages.groupChat.mentionPatterns"]
    },
    "multi_agent_quickstart": {
      "enable_agent_to_agent": {
        "tools.agentToAgent.enabled": true,
        "tools.agentToAgent.allow": ["*"],
        "sessions.visibility": "all"
      },
      "subagent_limits": {
        "agents.defaults.subagents.maxSpawnDepth": 2,
        "agents.defaults.subagents.maxConcurrent": 8,
        "agents.defaults.subagents.maxChildrenPerAgent": 5,
        "agents.defaults.subagents.runTimeoutSeconds": 900
      },
      "sessions_spawn_usage": "sessions_spawn({label: 'coder', task: 'Implement feature X'})"
    },
    "common_patterns": {
      "orchestrator": "Main agent spawns workers → workers complete → main synthesizes",
      "cost_control": "Main: opus (planning), Workers: sonnet-4.5 or local models",
      "nested": "Depth 2 max (main→sub→sub-sub), use with caution"
    }
  },
  "configuration_examples": {
    "basic_multi_agent": {
      "description": "Enable multi-agent with agent-to-agent communication",
      "config": {
        "tools": {
          "agentToAgent": {
            "enabled": true,
            "allow": ["*"]
          }
        },
        "sessions": {
          "visibility": "all"
        }
      }
    },
    "subagent_limits": {
      "description": "Control sub-agent spawning behavior",
      "config": {
        "agents": {
          "defaults": {
            "subagents": {
              "maxSpawnDepth": 2,
              "maxConcurrent": 8,
              "maxChildrenPerAgent": 5,
              "runTimeoutSeconds": 900
            }
          }
        }
      }
    },
    "cost_optimized": {
      "description": "Use different models for main vs workers",
      "config": {
        "agents": {
          "defaults": {
            "subagents": {
              "model": "anthropic/claude-sonnet-4-5",
              "thinking": "low"
            }
          },
          "list": [
            {
              "id": "main",
              "model": {"primary": "anthropic/claude-opus-4-6"}
            }
          ]
        }
      }
    },
    "sandbox_security": {
      "description": "Sandbox non-main sessions for security",
      "config": {
        "agents": {
          "defaults": {
            "sandbox": {
              "mode": "non-main",
              "backend": "docker",
              "scope": "agent"
            }
          }
        }
      }
    }
  }
}
